# Copy to .env (never commit .env) and fill in. All keys below are free.

# --- AI signal: Google Gemini (free, no credit card) ---
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- News (+ stock price fallback): Finnhub (free) ---
# https://finnhub.io
FINNHUB_API_KEY=

# --- Broker: Alpaca (free PAPER trading, no credit card) ---
# https://alpaca.markets  ->  Paper Trading  ->  API Keys
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Master safety switch. Leave false for paper (virtual money).
# Set true ONLY with LIVE keys and the intent to trade real money.
LIVE_TRADING=false

# --- Database ---
# Local dev: leave unset to use SQLite (data/app.db).
# Production: Supabase Postgres connection string (Project Settings -> Database).
#   postgresql://postgres:<password>@<host>:5432/postgres
# DATABASE_URL=

# --- Strategy / risk (optional overrides; defaults in app/config.py) ---
# MIN_CONFIDENCE=65
# REQUIRE_FRESH_NEWS=true
# NEWS_FRESH_HOURS=24
# MAX_POSITION_PCT=0.10
# MAX_OPEN_POSITIONS=5
# CASH_BUFFER_PCT=0.10
# ALLOW_SHORT=false
# STOP_LOSS_PCT=0.0
# TAKE_PROFIT_PCT=0.0
# TRADING_MODEL=
