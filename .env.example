# Copy to .env (never commit .env) and fill in. All keys below are free, no KYC.

# --- AI signal: Google Gemini (free, no credit card) ---
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- News: Finnhub (free) ---
# https://finnhub.io
FINNHUB_API_KEY=

# --- Broker: Binance Spot Testnet (free, no KYC, fake funds) ---
# https://testnet.binance.vision  ->  log in with GitHub  ->  Generate HMAC keys
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# true = testnet (fake money, default). Set false ONLY for real mainnet trading.
BINANCE_TESTNET=true
# Broker selector: "binance" (default) or "alpaca".
# BROKER=binance

# --- Database ---
# Local dev: leave unset to use SQLite (data/app.db).
# Production: Supabase Postgres connection string (use the Session pooler URI).
#   postgresql://postgres.<ref>:<password>@<host>:5432/postgres
# DATABASE_URL=

# --- Strategy / risk (optional overrides; defaults in app/config.py) ---
# MIN_CONFIDENCE=75
# REQUIRE_FRESH_NEWS=true
# NEWS_FRESH_HOURS=24
# MAX_POSITION_PCT=0.10
# MAX_OPEN_POSITIONS=5
# CASH_BUFFER_PCT=0.10
# STOP_LOSS_PCT=0.0
# TAKE_PROFIT_PCT=0.0
# TRADING_MODEL=
