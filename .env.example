# Copy to .env (never commit .env) and fill in. All keys below are free, no KYC.

# --- Broker: Binance USD-M Futures Testnet (free, no KYC, fake funds) ---
# Separate signup from spot: https://testnet.binancefuture.com -> log in -> API key
BINANCE_FUTURES_API_KEY=
BINANCE_FUTURES_SECRET_KEY=
# true = testnet (fake money, default). Set false ONLY for real mainnet trading.
BINANCE_FUTURES_TESTNET=true
# Broker selector: "binance_futures" (default), "binance" (spot), or "alpaca".
# BROKER=binance_futures
# FUTURES_LEVERAGE=3

# --- Database ---
# Local dev: leave unset to use SQLite (data/app.db).
# Production: Supabase Postgres connection string (use the Session pooler URI).
#   postgresql://postgres.<ref>:<password>@<host>:5432/postgres
# DATABASE_URL=

# --- Order-flow strategy (optional overrides; defaults in app/config.py) ---
# STRATEGY_HTF=4h
# STRATEGY_MTF=1h
# STRATEGY_LTF=15m
# MIN_CONFLUENCE=5            # how many checklist items must pass (strict)
# STRATEGY_REWARD_RISK=2.0
# RISK_PER_TRADE_PCT=0.005    # risk ~0.5% of equity per trade
# MAX_POSITION_PCT=0.10
# MAX_OPEN_POSITIONS=5
# CASH_BUFFER_PCT=0.10
# ALLOW_SHORT=true
# RUN_INTERVAL_MINUTES=30

# --- Optional: accuracy leaderboard only (not on the trading path) ---
# Spot testnet keys (https://testnet.binance.vision) if you also run BROKER=binance:
# BINANCE_API_KEY=
# BINANCE_SECRET_KEY=
# BINANCE_TESTNET=true
# Gemini + Finnhub power the legacy news leaderboard (app.cli predict):
# GEMINI_API_KEY=            # https://aistudio.google.com/app/apikey
# FINNHUB_API_KEY=           # https://finnhub.io
